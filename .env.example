# 이 파일을 .env 로 복사해서 사용하세요. (.env 는 절대 git 에 커밋하지 않습니다)
# 값을 비워두면 config.py 의 안전한 기본값이 사용됩니다.

# 세션 서명 키. 비워두면 instance/secret_key 에 자동 생성됩니다.
# 직접 지정하려면: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# HTTPS(ngrok 등) 로 서비스할 때 1 로 설정 → 세션 쿠키에 Secure 플래그 부여
SESSION_COOKIE_SECURE=0

# ngrok 같은 리버스 프록시 뒤에서 실제 클라이언트 IP를 쓰려면 1
# (프록시를 신뢰할 수 있을 때만 켜세요. 켜면 X-Forwarded-For 를 신뢰합니다)
TRUST_PROXY_HEADERS=0

# 세션 정책 (분)
SESSION_LIFETIME_MINUTES=60
IDLE_TIMEOUT_MINUTES=20
REAUTH_WINDOW_MINUTES=10

# 로그인 실패 제한
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=10

# 업로드
MAX_UPLOAD_MB=5

# 신고 임계치
REPORT_BLOCK_THRESHOLD_PRODUCT=3
REPORT_DORMANT_THRESHOLD_USER=5
REPORT_DAILY_LIMIT_PER_USER=10

# 채팅 스팸 방지 (WINDOW초 안에 MAX건)
CHAT_RATE_MAX=10
CHAT_RATE_WINDOW=10

# 서버
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=0
